{ch:7,q:"Cho 3,65 g HCl tan trong 100 mL nước, nồng độ mol của HCl trong dung dịch là:",o:["0,5 mol/L","1 mol/L","2 mol/L","0,1 mol/L"],a:1,e:"n(HCl)=3,65/36,5=0,1 mol; V=100 mL=0,1 L. C=n/V=0,1/0,1=1 mol/L."},
{ch:7,q:"Dùng thuốc thử AgNO₃ nhận biết 3 dung dịch NaCl, NaBr, NaI: hiện tượng lần lượt là:",o:["Cả 3 đều kết tủa trắng","AgCl trắng, AgBr vàng nhạt, AgI vàng","AgCl vàng, AgBr trắng, AgI không kết tủa","Cả 3 đều không tạo kết tủa"],a:1,e:"Ag⁺+Cl⁻→AgCl↓(trắng); Ag⁺+Br⁻→AgBr↓(vàng nhạt); Ag⁺+I⁻→AgI↓(vàng). Màu sắc khác nhau giúp nhận biết rõ ràng."},
{ch:7,q:"Tại sao F₂ có tính oxi hóa mạnh nhất trong nhóm halogen?",o:["F có bán kính nguyên tử lớn nhất","F có độ âm điện lớn nhất và bán kính nhỏ nhất","F có nhiều electron nhất","F₂ dễ tan trong nước nhất"],a:1,e:"F: độ âm điện 3,98 (cao nhất), bán kính nhỏ (64 pm) → hút electron rất mạnh → tính oxi hóa mạnh nhất."}
];

let filtered=ALL, cur=0, correct=0, answered=0;
const answered_map={};
const labels=['A','B','C','D'];
const chName={5:'Chương 5 — Năng lượng',6:'Chương 6 — Tốc độ',7:'Chương 7 — Halogen'};
const chCls={5:'ch5-badge',6:'ch6-badge',7:'ch7-badge'};

function setFilter(ch,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('on'));
  el.classList.add('on');
  filtered=ch===0?ALL:ALL.filter(q=>q.ch===ch);
  cur=0; renderQ();
}

function renderQ(){
  const q=filtered[cur];
  if(!q){showSummary();return;}
  const id=ALL.indexOf(q);
  const ans=answered_map[id];
  let html=`<div class="qcard">
    <div class="qcard-top">
      <div class="qmeta">
        <span class="ch-badge ${chCls[q.ch]}">${chName[q.ch]}</span>
        <span class="qnum-label">Câu ${cur+1} / ${filtered.length}</span>
      </div>
      <div class="qtext">${q.q}</div>
    </div>
    <div class="options">`;
  q.o.forEach((opt,i)=>{
    let cls='opt';
    let icon='';
    if(ans!==undefined){
      cls+=' disabled';
      if(i===q.a){ cls+=' correct'; icon='<span class="opt-icon">✓</span>'; }
      else if(i===ans&&ans!==q.a){ cls+=' wrong'; icon='<span class="opt-icon">✗</span>'; }
    }
    html+=`<div class="${cls}" onclick="choose(${i})">
      <span class="opt-label">${labels[i]}</span>
      <span class="opt-text">${opt}</span>
      ${icon}
    </div>`;
  });
  html+=`</div>`;
  if(ans!==undefined){
    html+=`<div class="explain"><div class="explain-title">💡 Giải thích</div>${q.e}</div>`;
  }
  html+=`</div>`;
  document.getElementById('qarea').innerHTML=html;
  document.getElementById('qpos').textContent=`${cur+1} / ${filtered.length}`;
  document.getElementById('prevBtn').disabled=cur===0;
  document.getElementById('nextBtn').textContent=cur===filtered.length-1?'Xem kết quả ✓':'Câu sau →';
  const pct=Math.round((cur/filtered.length)*100);
  document.getElementById('prog').style.width=pct+'%';
  document.getElementById('progLabel').textContent=`Câu ${cur+1} / ${filtered.length}`;
  document.getElementById('progPct').textContent=pct+'%';
  updateScore();
}

function choose(i){
  const q=filtered[cur];
  const id=ALL.indexOf(q);
  if(answered_map[id]!==undefined) return;
  answered_map[id]=i;
  answered++;
  if(i===q.a) correct++;
  renderQ();
}

function go(dir){
  if(dir===1&&cur===filtered.length-1){showSummary();return;}
  cur=Math.max(0,Math.min(filtered.length-1,cur+dir));
  renderQ();
}

function updateScore(){
  document.getElementById('scorebox').textContent=`Điểm: ${correct} / ${answered}`;
}

function showSummary(){
  const pct=answered>0?Math.round(correct/answered*100):0;
  const emoji=pct>=80?'🎉':pct>=60?'👍':'📚';
  const msg=pct>=80?'Xuất sắc! Bạn đã nắm vững kiến thức chương này!':pct>=60?'Khá tốt! Xem lại phần còn sai nhé!':'Cần ôn tập thêm — đừng nản, thử lại nào!';
  const wrong=answered-correct;
  const radius=54; const circ=2*Math.PI*radius;
  const dashArr=circ*(pct/100);
  document.getElementById('qarea').innerHTML=`<div class="summary">
    <div class="summary-top">
      <div class="summary-emoji">${emoji}</div>
      <div class="summary-title">Kết quả luyện tập</div>
      <div class="summary-sub">Bạn đã hoàn thành bộ câu hỏi!</div>
    </div>
    <div class="summary-body">
      <div class="score-ring">
        <svg width="140" height="140" viewBox="0 0 140 140">
          <circle cx="70" cy="70" r="${radius}" fill="none" stroke="#e2e8f0" stroke-width="12"/>
          <circle cx="70" cy="70" r="${radius}" fill="none" stroke="#6366f1" stroke-width="12"
            stroke-dasharray="${dashArr} ${circ}" stroke-linecap="round"/>
        </svg>
        <div class="score-ring-inner">
          <div class="score-big">${pct}<span style="font-size:18px">%</span></div>
          <div class="score-denom">${correct}/${answered}</div>
        </div>
      </div>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="num" style="color:#16a34a">${correct}</div>
          <div class="lbl">✓ Câu đúng</div>
        </div>
        <div class="stat-card">
          <div class="num" style="color:#dc2626">${wrong}</div>
          <div class="lbl">✗ Câu sai</div>
        </div>
        <div class="stat-card">
          <div class="num">${answered}</div>
          <div class="lbl">📝 Đã làm</div>
        </div>
        <div class="stat-card">
          <div class="num">${filtered.length-answered}</div>
          <div class="lbl">⏭ Bỏ qua</div>
        </div>
      </div>
      <div class="msg-box">${msg}</div>
      <button class="btn-restart" onclick="resetAll()">🔄 Làm lại từ đầu</button>
    </div>
  </div>`;
  document.getElementById('qpos').textContent='';
  document.getElementById('prevBtn').disabled=true;
  document.getElementById('nextBtn').textContent='Câu sau →';
  document.getElementById('prog').style.width='100%';
  document.getElementById('progPct').textContent='100%';
}

function resetAll(){
  Object.keys(answered_map).forEach(k=>delete answered_map[k]);
  correct=0; answered=0; cur=0;
  updateScore(); renderQ();
}

renderQ();
</script>
</body>
</html>
